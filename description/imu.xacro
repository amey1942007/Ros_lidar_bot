<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =======================================================================
       IMU POSITION — FILL IN YOUR VALUES (metres)
       Reference Point:
         Measure X, Y, Z offsets relative to the 'base_link' origin.
         - 'base_link' is located at the center of the bottom face of the chassis box.
         - X: distance forward from the center of the chassis bottom (positive front, negative back).
         - Y: distance left from the center of the chassis bottom (positive left, negative right).
         - Z: height upwards from the center of the chassis bottom face.
       ======================================================================= -->
  <xacro:property name="imu_x"  value="-0.115"/>  <!-- forward/back  -->
  <xacro:property name="imu_y"  value="0.0"/>  <!-- left/right    -->
  <xacro:property name="imu_z"  value="0.004"/>  <!-- height        -->

  <!-- IMU box size (small PCB) -->
  <xacro:property name="imu_size_x" value="0.030"/>
  <xacro:property name="imu_size_y" value="0.020"/>
  <xacro:property name="imu_size_z" value="0.001"/>

  <!-- ============================================================
       IMU JOINT & LINK
       ============================================================ -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="${imu_x} ${imu_y} ${imu_z}" rpy="${pi} 0 0"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${imu_size_x} ${imu_size_y} ${imu_size_z}"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 0.8 0.0 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${imu_size_x} ${imu_size_y} ${imu_size_z}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia
        ixx="${(1.0/12.0)*0.01*(imu_size_y*imu_size_y + imu_size_z*imu_size_z)}"
        iyy="${(1.0/12.0)*0.01*(imu_size_x*imu_size_x + imu_size_z*imu_size_z)}"
        izz="${(1.0/12.0)*0.01*(imu_size_x*imu_size_x + imu_size_y*imu_size_y)}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

</robot>