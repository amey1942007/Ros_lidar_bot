<?xml version = "1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<!--
  Differential Drive plugin for Ignition Gazebo 6 (Fortress) + ROS2 Humble.

  IMPORTANT notes on names:
    • filename="ignition-gazebo-diff-drive-system"  ← Fortress short-name (NO lib prefix, NO .so)
    • libgz-sim-diff-drive-system.so                ← Harmonic/Iron ONLY, does NOT exist in Humble
-->
<gazebo>
  <plugin
    filename="ignition-gazebo-diff-drive-system"
    name="ignition::gazebo::systems::DiffDrive">

      <!-- Wheel joints (must match joint names in robot_core.xacro) -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <!-- Physical parameters — must match the URDF geometry exactly -->
      <wheel_separation>0.230</wheel_separation>
      <wheel_radius>0.081</wheel_radius>

      <!-- Conservative limits: prevents wheel slip which ruins odometry -->
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.5</max_wheel_acceleration>

      <!-- TF frame IDs — must match SLAM/URDF frame names -->
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>

      <!--
        Topic — use ABSOLUTE path (leading slash) so it matches the
        ros_gz_bridge entry exactly:  /cmd_vel@Twist]ignition.msgs.Twist
        If you use a relative name like "cmd_vel", Ignition may namespace it
        under the model and the bridge will never deliver commands → no motion.
      -->
      <topic>/cmd_vel</topic>
      <tf_topic>/tf</tf_topic>
      <odom_topic>/odom</odom_topic>
      <robot_base_frame>base_link</robot_base_frame>

      <!-- Publishing -->
      <publish_odom>true</publish_odom>

      <!-- odom→base_link TF published via Ignition /tf topic → bridged to ROS -->
      <publish_odom_tf>true</publish_odom_tf>

      <!--
        publish_wheel_tf: publishes base_link→left_wheel / base_link→right_wheel
        via Ignition /tf (bridged to ROS).  This lets robot_state_publisher
        skip the wheel joint TF so we do NOT need the joint_states bridge.
      -->
      <publish_wheel_tf>true</publish_wheel_tf>

  </plugin>
</gazebo>

<!--
  Caster wheel friction.
  In Ignition Gazebo URDF extensions (sdformat_urdf / gz_urdf for Fortress),
  the correct format inside <gazebo reference="..."> IS the simple element form:
    <mu1>value</mu1>   (not <mu1 value="..."/>)
  Keep values very low so the caster slides freely and the robot can turn.
  The <surface><friction><ode> block does NOT work through URDF→SDF conversion.
-->
<gazebo reference="ball_caster_wheel__1__1">
  <mu1>0.001</mu1>
  <mu2>0.001</mu2>
  <kp>1000000.0</kp>
  <kd>100.0</kd>
</gazebo>

<gazebo reference="ball_caster_wheel_1">
  <mu1>0.001</mu1>
  <mu2>0.001</mu2>
  <kp>1000000.0</kp>
  <kd>100.0</kd>
</gazebo>

</robot>