<?xml version = "1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<gazebo>
  <plugin
    filename="libgz-sim-diff-drive-system.so"
    name="gz::sim::systems::DiffDrive">

        <!--Wheel information -->
        <left_joint>left_wheel_joint</left_joint>
        <right_joint>right_wheel_joint</right_joint>

        <wheel_separation>0.35</wheel_separation>
        <wheel_radius>0.05</wheel_radius>

        <!-- limits — kept low to prevent wheel slip and odometry drift -->
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>1.5</max_wheel_acceleration>

        <frame_id>odom</frame_id>
        <child_frame_id>base_link</child_frame_id>
        <tf_topic>/tf</tf_topic>
        <odom_topic>/odom</odom_topic>

        <!-- outputs-->
        <robot_base_frame>base_link</robot_base_frame>

        <!-- topics-->
        <topic>cmd_vel</topic> 
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>true</publish_wheel_tf>
  </plugin>

</gazebo>
<gazebo reference="caster_wheel">
  <!-- Near-zero friction so caster spins freely without resisting motion -->
  <mu1>0.001</mu1>
  <mu2>0.001</mu2>
  <kp>1000000.0</kp>
  <kd>100.0</kd>
</gazebo>

</robot>