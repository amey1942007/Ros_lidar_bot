<?xml version="1.0" ?>
<robot name="slam" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       CHASSIS & WHEEL DIMENSIONS — FILL IN YOUR VALUES (metres)
       ============================================================ -->

  <!-- Chassis box size -->
  <xacro:property name="chassis_length"  value="0.0"/>   <!-- front-to-back   -->
  <xacro:property name="chassis_width"   value="0.0"/>   <!-- left-to-right   -->
  <xacro:property name="chassis_height"  value="0.0"/>   <!-- bottom-to-top   -->

  <!-- Drive wheel -->
  <xacro:property name="wheel_radius"    value="0.05035"/>   <!-- RADIUS = 50.35 mm (from sketch) -->
  <xacro:property name="wheel_width"     value="0.0"/>       <!-- axial thickness -->
  <!-- X position of wheel axle from robot centre (0 = at centre) -->
  <xacro:property name="wheel_x"         value="0.0"/>
  <!-- Half-separation: each wheel is this far from the centre in Y
       Text said 33cm → 0.165; sketch front-face shows ~35cm → 0.175
       CONFIRM and update this value! -->
  <xacro:property name="wheel_half_sep"  value="0.165"/>
  <!-- Wheel centre height above chassis bottom (base_link) = 11 mm -->
  <xacro:property name="wheel_z"         value="0.011"/>

  <!-- Caster wheels -->
  <xacro:property name="caster_radius"    value="0.0"/>  <!-- ball caster radius -->
  <xacro:property name="caster_front_x"  value="0.0"/>   <!-- front caster X     -->
  <xacro:property name="caster_rear_x"   value="0.0"/>   <!-- rear  caster X     -->

  <!-- ============================================================
       DERIVED VALUE
       base_link sits (wheel_radius - wheel_z) above the ground
       so base_footprint → base_link offset = wheel_radius - wheel_z
       ============================================================ -->
  <xacro:property name="ground_to_base"  value="${wheel_radius - wheel_z}"/>

  <!-- ============================================================
       MATERIALS
       ============================================================ -->
  <material name="white"><color rgba="1.0 1.0 1.0 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="grey" ><color rgba="0.5 0.5 0.5 1.0"/></material>

  <!-- ============================================================
       base_footprint  (ground-plane projection, zero-size link)
       ============================================================ -->
  <link name="base_footprint"/>

  <!-- base_footprint → base_link
       base_link is at the centre of the BOTTOM FACE of the chassis box.
       It sits (wheel_radius - wheel_z) above ground so wheels touch ground. -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${ground_to_base}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       base_link / CHASSIS
       Visual box offset by chassis_height/2 upward so the box
       sits entirely above base_link (= chassis bottom face centre).
       ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Centre of mass at geometric centre of box -->
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia
        ixx="${(1.0/12.0)*2.0*(chassis_width*chassis_width + chassis_height*chassis_height)}"
        iyy="${(1.0/12.0)*2.0*(chassis_length*chassis_length + chassis_height*chassis_height)}"
        izz="${(1.0/12.0)*2.0*(chassis_length*chassis_length + chassis_width*chassis_width)}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

  <!-- ============================================================
       LEFT WHEEL  (positive Y side)
       Joint origin = physical centre of wheel relative to base_link.
       Link visual/collision has ZERO local offset → correct TF.
       Cylinder lies along Z by default; rotate pi/2 about X to align
       rotation axis with Y-axis.
       ============================================================ -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel"/>
    <origin xyz="${wheel_x} ${wheel_half_sep} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="${(1.0/12.0)*0.5*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        iyy="${(1.0/2.0)*0.5*wheel_radius*wheel_radius}"
        izz="${(1.0/12.0)*0.5*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

  <!-- ============================================================
       RIGHT WHEEL  (negative Y side)
       ============================================================ -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel"/>
    <origin xyz="${wheel_x} ${-wheel_half_sep} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <mass value="0.5"/>
      <inertia
        ixx="${(1.0/12.0)*0.5*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        iyy="${(1.0/2.0)*0.5*wheel_radius*wheel_radius}"
        izz="${(1.0/12.0)*0.5*(3*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

  <!-- ============================================================
       FRONT CASTER  (passive ball caster — fixed joint)
       ============================================================ -->
  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_front_link"/>
    <!-- caster centre sits at wheel ground level; same Z as drive wheel bottom -->
    <origin xyz="${caster_front_x} 0 ${caster_radius}" rpy="0 0 0"/>
  </joint>

  <link name="caster_front_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="${(2.0/5.0)*0.05*caster_radius*caster_radius}"
        iyy="${(2.0/5.0)*0.05*caster_radius*caster_radius}"
        izz="${(2.0/5.0)*0.05*caster_radius*caster_radius}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

  <!-- ============================================================
       REAR CASTER  (passive ball caster — fixed joint)
       ============================================================ -->
  <joint name="caster_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_rear_link"/>
    <origin xyz="${caster_rear_x} 0 ${caster_radius}" rpy="0 0 0"/>
  </joint>

  <link name="caster_rear_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia
        ixx="${(2.0/5.0)*0.05*caster_radius*caster_radius}"
        iyy="${(2.0/5.0)*0.05*caster_radius*caster_radius}"
        izz="${(2.0/5.0)*0.05*caster_radius*caster_radius}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

</robot>
