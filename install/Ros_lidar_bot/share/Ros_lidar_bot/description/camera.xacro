<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       CAMERA POSITION — FILL IN YOUR VALUES (metres, from base_link)
       ============================================================ -->
  <xacro:property name="cam_x"  value="0.0"/>  <!-- forward/back  -->
  <xacro:property name="cam_y"  value="0.0"/>  <!-- left/right    -->
  <xacro:property name="cam_z"  value="0.0"/>  <!-- height        -->

  <!-- Camera box size  -->
  <xacro:property name="cam_size_x" value="0.025"/>  <!-- depth         -->
  <xacro:property name="cam_size_y" value="0.090"/>  <!-- width         -->
  <xacro:property name="cam_size_z" value="0.025"/>  <!-- height        -->

  <!-- ============================================================
       CAMERA JOINT & LINK
       ============================================================ -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${cam_x} ${cam_y} ${cam_z}" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_size_x} ${cam_size_y} ${cam_size_z}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.3 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${cam_size_x} ${cam_size_y} ${cam_size_z}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia
        ixx="${(1.0/12.0)*0.01*(cam_size_y*cam_size_y + cam_size_z*cam_size_z)}"
        iyy="${(1.0/12.0)*0.01*(cam_size_x*cam_size_x + cam_size_z*cam_size_z)}"
        izz="${(1.0/12.0)*0.01*(cam_size_x*cam_size_x + cam_size_y*cam_size_y)}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

  <!-- Camera optical frame (ROS convention: Z forward, X right, Y down) -->
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <link name="camera_link_optical"/>

</robot>
