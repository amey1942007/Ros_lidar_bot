<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       LIDAR POSITION — FILL IN YOUR VALUES (metres, from base_link)
       Lidar is on the 2nd floor of the chassis.
       ============================================================ -->
  <xacro:property name="laser_x"      value="0.0"/>  <!-- forward/back  -->
  <xacro:property name="laser_y"      value="0.0"/>  <!-- left/right    -->
  <xacro:property name="laser_z"      value="0.0"/>  <!-- height above base_link (2nd floor) -->

  <!-- Lidar cylinder dimensions (default ~RPLidar A1) -->
  <xacro:property name="laser_radius" value="0.035"/> <!-- 70 mm diameter -->
  <xacro:property name="laser_height" value="0.040"/> <!-- 40 mm tall     -->

  <!-- ============================================================
       LIDAR JOINT & LINK
       ============================================================ -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <origin xyz="${laser_x} ${laser_y} ${laser_z}" rpy="0 0 0"/>
  </joint>

  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${laser_radius}" length="${laser_height}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${laser_radius}" length="${laser_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia
        ixx="${(1.0/12.0)*0.2*(3*laser_radius*laser_radius + laser_height*laser_height)}"
        iyy="${(1.0/12.0)*0.2*(3*laser_radius*laser_radius + laser_height*laser_height)}"
        izz="${(1.0/2.0)*0.2*laser_radius*laser_radius}"
        ixy="0" iyz="0" ixz="0"/>
    </inertial>
  </link>

</robot>
