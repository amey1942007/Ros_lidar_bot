<?xml version="1.0" ?>
<!--
  apartment.world — 12 × 10 m residential apartment
  Robot spawns at (0, 0) in the left zone (bedroom + kitchen).
  Internal wall at x = 0.5 divides LEFT (bedroom y>0, kitchen y<0)
  from RIGHT (living room). Doorway at y = 1.0 – 2.4 (1.4 m gap).

  YOLO classes by zone:
    BEDROOM  : person, bed
    KITCHEN  : dining table, chair (×4), refrigerator, microwave, bottle, cup
    LIVING   : couch, chair (×2), tv, potted plant, backpack, suitcase, clock

  Dead-zone features:
    • Wardrobe flush against west wall — interior void permanently occluded
    • Bookshelf flush against east wall — rear strip occluded
    • Sink counter flush against south wall — rear strip occluded
    • Closet alcove (partial wall NW corner) — L-shaped dead-end pocket

  All collision geometry crosses z = 0.20 m (LiDAR scan plane).
-->
<sdf version="1.6">
<world name="default">

  <plugin filename="libignition-gazebo-physics-system.so"       name="ignition::gazebo::systems::Physics"/>
  <plugin filename="libignition-gazebo-user-commands-system.so" name="ignition::gazebo::systems::UserCommands"/>
  <plugin filename="libignition-gazebo-scene-broadcaster-system.so" name="ignition::gazebo::systems::SceneBroadcaster"/>
  <plugin filename="libignition-gazebo-imu-system.so"           name="ignition::gazebo::systems::Imu"/>
  <plugin filename="libignition-gazebo-sensors-system.so"       name="ignition::gazebo::systems::Sensors">
    <render_engine>ogre2</render_engine>
  </plugin>

  <physics name="default_physics" default="true" type="ode">
    <max_step_size>0.001</max_step_size>
    <real_time_factor>1</real_time_factor>
    <real_time_update_rate>500</real_time_update_rate>
    <gravity>0 0 -9.81</gravity>
  </physics>

  <light name="sun" type="directional">
    <cast_shadows>false</cast_shadows>
    <pose>0 0 12 0 -0.4 0.6</pose>
    <diffuse>1.0 0.98 0.94 1</diffuse>
    <specular>0.3 0.3 0.3 1</specular>
    <direction>-0.4 0.2 -0.9</direction>
  </light>
  <light name="fill" type="directional">
    <cast_shadows>false</cast_shadows>
    <pose>0 0 8 0 0 0</pose>
    <diffuse>0.50 0.52 0.56 1</diffuse>
    <specular>0.02 0.02 0.02 1</specular>
    <direction>0 0 -1</direction>
  </light>

  <!-- ══ FLOOR ══ -->
  <model name="floor"><static>true</static><pose>0 0 0.01 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>12.0 10.0 0.02</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>12.0 10.0 0.02</size></box></geometry>
        <material><ambient>0.78 0.74 0.66 1</ambient><diffuse>0.85 0.81 0.73 1</diffuse></material></visual></link></model>

  <!-- ══ OUTER WALLS ══ -->
  <model name="wall_N"><static>true</static><pose>0 5.0 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>12.4 0.20 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>12.4 0.20 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>
  <model name="wall_S"><static>true</static><pose>0 -5.0 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>12.4 0.20 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>12.4 0.20 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>
  <model name="wall_E"><static>true</static><pose>6.0 0 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.20 10.4 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.20 10.4 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>
  <model name="wall_W"><static>true</static><pose>-6.0 0 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.20 10.4 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.20 10.4 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>

  <!-- ══ INTERNAL DIVIDING WALL x=0.5  (doorway y=1.0–2.4) ══ -->
  <model name="div_N"><static>true</static><pose>0.5 3.70 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.20 2.60 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.20 2.60 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>
  <model name="div_S"><static>true</static><pose>0.5 -2.0 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.20 6.00 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.20 6.00 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>

  <!-- ══ CLOSET ALCOVE — partial wall creates dead-end pocket ══
       Wall at x=-4.2, y=3.0–5.0 closes off NW corner as closet.
       Robot can enter from south (y<3.0) but the far corner
       behind the wardrobe stays permanently occluded.              -->
  <model name="closet_wall"><static>true</static><pose>-4.2 4.0 1.35 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.20 2.00 2.70</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.20 2.00 2.70</size></box></geometry>
        <material><ambient>0.92 0.90 0.86 1</ambient><diffuse>0.96 0.94 0.90 1</diffuse></material></visual></link></model>

  <!-- ══════════════════════════════════════════════════════════════
       BEDROOM  (left zone, y > 0)
       Classes: bed, person
  ══════════════════════════════════════════════════════════════════ -->

  <!-- BED — class: bed -->
  <model name="bed_mat"><static>true</static><pose>-3.5 3.2 0.25 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>1.90 1.30 0.50</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>1.90 1.30 0.50</size></box></geometry>
        <material><ambient>0.94 0.91 0.86 1</ambient><diffuse>0.98 0.95 0.90 1</diffuse></material></visual></link></model>
  <model name="bed_head"><static>true</static><pose>-3.5 3.87 0.45 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>1.90 0.12 0.90</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>1.90 0.12 0.90</size></box></geometry>
        <material><ambient>0.35 0.22 0.10 1</ambient><diffuse>0.44 0.28 0.14 1</diffuse></material></visual></link></model>
  <model name="bed_pillow"><static>true</static><pose>-3.5 3.55 0.545 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>1.00 0.50 0.14</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>1.00 0.50 0.14</size></box></geometry>
        <material><ambient>0.97 0.96 0.94 1</ambient><diffuse>1.0 0.99 0.97 1</diffuse></material></visual></link></model>

  <!-- WARDROBE — flush west wall — void behind creates dead zone -->
  <model name="wardrobe"><static>true</static><pose>-5.70 1.8 0.96 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.60 1.20 1.92</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.60 1.20 1.92</size></box></geometry>
        <material><ambient>0.30 0.20 0.10 1</ambient><diffuse>0.38 0.26 0.14 1</diffuse></material></visual></link></model>

  <!-- PERSON — class: person -->
  <model name="person_body"><static>true</static><pose>-1.8 2.8 0.80 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><cylinder><radius>0.18</radius><length>1.60</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.18</radius><length>1.60</length></cylinder></geometry>
        <material><ambient>0.42 0.30 0.22 1</ambient><diffuse>0.52 0.38 0.28 1</diffuse></material></visual></link></model>
  <model name="person_head"><static>true</static><pose>-1.8 2.8 1.70 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><sphere><radius>0.13</radius></sphere></geometry></collision>
      <visual name="v"><geometry><sphere><radius>0.13</radius></sphere></geometry>
        <material><ambient>0.86 0.68 0.52 1</ambient><diffuse>0.92 0.76 0.60 1</diffuse></material></visual></link></model>

  <!-- NIGHTSTAND -->
  <model name="nstand_body"><static>true</static><pose>-4.6 2.4 0.26 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.44 0.36 0.52</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.44 0.36 0.52</size></box></geometry>
        <material><ambient>0.72 0.56 0.38 1</ambient><diffuse>0.80 0.64 0.46 1</diffuse></material></visual></link></model>
  <model name="nstand_top"><static>true</static><pose>-4.6 2.4 0.54 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.48 0.40 0.04</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.48 0.40 0.04</size></box></geometry>
        <material><ambient>0.75 0.60 0.40 1</ambient><diffuse>0.82 0.67 0.47 1</diffuse></material></visual></link></model>

  <!-- ══════════════════════════════════════════════════════════════
       KITCHEN / DINING  (left zone, y < 0)
       Classes: dining table, chair (×4), refrigerator, microwave,
                bottle (×2), cup
  ══════════════════════════════════════════════════════════════════ -->

  <!-- DINING TABLE — class: dining table -->
  <model name="dtable_top"><static>true</static><pose>-2.5 -2.2 0.73 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>1.60 0.90 0.04</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>1.60 0.90 0.04</size></box></geometry>
        <material><ambient>0.78 0.63 0.42 1</ambient><diffuse>0.86 0.71 0.50 1</diffuse></material></visual></link></model>
  <model name="dtable_leg_ne"><static>true</static><pose>-1.72 -1.77 0.365 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry>
        <material><ambient>0.55 0.42 0.26 1</ambient><diffuse>0.62 0.48 0.30 1</diffuse></material></visual></link></model>
  <model name="dtable_leg_nw"><static>true</static><pose>-3.28 -1.77 0.365 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry>
        <material><ambient>0.55 0.42 0.26 1</ambient><diffuse>0.62 0.48 0.30 1</diffuse></material></visual></link></model>
  <model name="dtable_leg_se"><static>true</static><pose>-1.72 -2.63 0.365 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry>
        <material><ambient>0.55 0.42 0.26 1</ambient><diffuse>0.62 0.48 0.30 1</diffuse></material></visual></link></model>
  <model name="dtable_leg_sw"><static>true</static><pose>-3.28 -2.63 0.365 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry></collision>
      <visual name="v"><geometry><cylinder><radius>0.04</radius><length>0.73</length></cylinder></geometry>
        <material><ambient>0.55 0.42 0.26 1</ambient><diffuse>0.62 0.48 0.30 1</diffuse></material></visual></link></model>

  <!-- CHAIR N (north of table, faces south) — class: chair -->
  <model name="chair_n_seat"><static>true</static><pose>-2.5 -1.25 0.44 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.42 0.42 0.04</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.42 0.42 0.04</size></box></geometry>
        <material><ambient>0.50 0.38 0.26 1</ambient><diffuse>0.60 0.46 0.32 1</diffuse></material></visual></link></model>
  <model name="chair_n_back"><static>true</static><pose>-2.5 -1.06 0.65 0 0 0</pose>
