  <!-- CHAIR W (west of table, faces east) -->
  <model name="chair_w_seat"><static>true</static><pose>-3.68 -2.20 0.44 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.42 0.42 0.04</size></box></geometry></collision>
