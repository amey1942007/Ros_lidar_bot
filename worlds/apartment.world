        <material><ambient>0.38 0.24 0.12 1</ambient><diffuse>0.46 0.30 0.16 1</diffuse></material></visual></link></model>
  <model name="chair_n_leg_sw"><static>true</static><pose>-2.71 -1.46 0.22 0 0 0</pose>
