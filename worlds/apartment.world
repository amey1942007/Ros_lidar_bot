        <material><ambient>0.40 0.26 0.14 1</ambient><diffuse>0.50 0.34 0.20 1</diffuse></material></visual></link></model>
  <model name="chair_n_leg_ne"><static>true</static><pose>-2.29 -1.04 0.22 0 0 0</pose>
