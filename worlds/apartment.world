      <visual name="v"><geometry><box><size>0.05 0.05 0.44</size></box></geometry>
        <material><ambient>0.38 0.24 0.12 1</ambient><diffuse>0.46 0.30 0.16 1</diffuse></material></visual></link></model>
  <model name="chair_n_leg_nw"><static>true</static><pose>-2.71 -1.04 0.22 0 0 0</pose>
    <link name="l"><collision name="c"><geometry><box><size>0.05 0.05 0.44</size></box></geometry></collision>
      <visual name="v"><geometry><box><size>0.05 0.05 0.44</size></box></geometry>
        <material><ambient>0.38 0.24 0.12 1</ambient><diffuse>0.46 0.30 0.16 1</diffuse></material></visual></link></model>
  <model name="chair_n_leg_se"><static>true</static><pose>-2.29 -1.46 0.22 0 0 0</pose>
